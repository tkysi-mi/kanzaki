{
  "name": "kanzaki",
  "version": "0.3.1",
  "description": "LLM-powered semantic pre-commit linter. Define rules in Markdown, review diffs with AI.",
  "type": "module",
  "bin": {
    "kanzaki": "dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "format": "biome format --write src",
    "check": "biome check --write src"
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "linter",
    "pre-commit",
    "llm",
    "ai",
    "code-review",
    "semantic"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "open": "^11.0.0",
    "openai": "^4.85.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
