{
  "name": "kanzaki",
  "version": "0.3.2",
  "description": "LLM-powered semantic pre-commit linter. Define rules in Markdown, review diffs with AI.",
  "type": "module",
  "author": "tkysi-mi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkysi-mi/kanzaki.git"
  },
  "bugs": {
    "url": "https://github.com/tkysi-mi/kanzaki/issues"
  },
  "homepage": "https://github.com/tkysi-mi/kanzaki#readme",
  "bin": {
    "kanzaki": "dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/e2e/**'",
    "test:watch": "vitest --exclude 'src/e2e/**'",
    "test:e2e": "npm run build && vitest run src/e2e",
    "lint": "biome check src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "knip": "knip",
    "publint": "publint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "linter",
    "pre-commit",
    "llm",
    "ai",
    "code-review",
    "semantic"
  ],
  "engines": {
    "node": ">=20.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "openai": "^6.34.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "publint": "^0.3.18",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
